{
    "name": "dory",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "compile": "tsc -p tsconfig.json && node ./scripts/copy-assets.cjs",
        "dev": "yarn run compile && electron ./dist-electron/main.js",
        "dev:app": "yarn run compile && electron-builder --mac --dir && open \"dist/mac-arm64/Dory.app\"",
        "electron:standalone": "bash ../../scripts/build-app-standalone.sh",
        "build": "yarn --cwd ../web run build && yarn run compile && electron-builder",
        "electron:build:apple": "yarn run compile && electron-builder --mac"
    },
    "devDependencies": {
        "@types/node": "^24.3.1",
        "dotenv": "^17.2.3",
        "electron": "38.7.2",
        "electron-builder": "^25.1.8",
        "electron-notarize": "^1.2.2",
        "typescript": "^5.9.3"
    },
    "dependencies": {
        "electron-log": "^5.4.3",
        "electron-store": "^9.0.0"
    }
}
