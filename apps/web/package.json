{
  "name": "web",
  "version": "0.7.6",
  "description": "Dory",
  "author": "Dory Lab",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "yarn run prebuild && tsx ./scripts/dev-bootstrap.ts && next dev --turbopack",
    "prebuild": "yarn run client:migrate:compile",
    "build": "yarn run build:bootstrap && next build",
    "build:cf": "next build && opennextjs-cloudflare build",
    "build:bootstrap": "bun build scripts/bootstrap.ts --target=node --format=esm --outfile=./dist-scripts/bootstrap.mjs && node scripts/copy-pglite-assets.mjs",
    "start": "next start",
    "studio": "drizzle-kit studio",
    "pglite:studio": "drizzle-kit studio --config ./drizzle.pglite.config.ts",
    "drizzle:push": "drizzle-kit push",
    "drizzle:migrate": "tsx ./scripts/migrate.ts",
    "demo:backfill": "tsx ./scripts/backfill-demo-connections.ts",
    "postgres:check": "tsx ./scripts/check-postgres-connection.ts",
    "postgres:repair-migrations": "tsx ./scripts/repair-drizzle-migrations.ts",
    "postgres:migrate:generate": "drizzle-kit generate",
    "migrate:generate": "drizzle-kit generate && yarn run pglite:migrate:compile && yarn run client:migrate:compile && yarn run build:bootstrap",
    "pglite:migrate:generate": "drizzle-kit generate --config ./drizzle.pglite.config.ts",
    "pglite:migrate:compile": "yarn run pglite:migrate:generate && tsx ./scripts/compile-pglite-migrations.ts",
    "pglite:seed:queries": "tsx ./lib/database/pglite/seeds/seed-saved-queries.ts",
    "client:migrate:generate": "drizzle-kit generate --config ./lib/client/drizzle.config.ts",
    "client:migrate:compile": "drizzle-kit generate --config ./lib/client/drizzle.config.ts && tsx ./scripts/compile-client-migrations.ts",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "typecheck": "tsc --noEmit",
    "format:write": "prettier --write \"**/*.{ts,tsx,mdx}\" --cache",
    "format:check": "prettier --check \"**/*.{ts,tsx,mdx}\" --cache",
    "test:clean-json": "tsx ./scripts/tests/clean-json.test.ts",
    "release-notes": "tsx ./scripts/release-notes/generate.ts",
    "docker:build": "docker build --build-arg VERSION=$(git rev-parse HEAD) -t dorylab/dory .",
    "docker:quickstart": "docker run -d --name dory -p 3000:3000 -e TRUSTED_ORIGINS=\"http://localhost:3000\" -e DS_SECRET_KEY=\"$(openssl rand -base64 32 | tr -d '\\n')\" -e BETTER_AUTH_SECRET=\"$(openssl rand -hex 32)\" dorylab/dory:latest",
    "docker:run": "docker run -d --name dory -p 3000:3000 --env-file=.env dorylab/dory:latest",
    "registry:build": "tsx --tsconfig ./tsconfig.scripts.json ./scripts/build-registry.mts && prettier --log-level silent --write \"registry/**/*.{ts,tsx,json,mdx}\" --cache"
  },
